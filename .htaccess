# ── Configuration AED Congo (Netlify Optimized) ───────────────────────

# Note: La plupart des configurations (HTTPS, Security Headers, Redirects) 
# sont désormais gérées par le fichier netlify.toml pour plus de performance.

# 1. URLs Propres (Supprimer le .html pour les serveurs classiques)
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [NC,L]

# 2. Redirections de compatibilité (Anciennes URLs vers nouvelles structures)
RewriteRule ^index\.html$ / [R=301,L]
RewriteRule ^aed-main-page\.html$ / [R=301,L]
RewriteRule ^aed-studies-improved\.html$ /etudes/ [R=301,L]
RewriteRule ^nos-actions\.html$ /actions/ [R=301,L]
RewriteRule ^page-nous-soutenir\.html$ /nous-soutenir/ [R=301,L]

# 3. Page d'erreur 404
ErrorDocument 404 /404.html
