                    <svg viewBox="0 0 24 24">
                        {% if loop.index == 1 %}
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                        {% elif loop.index == 2 %}
                        <path d="M12 22V12"/>
                        <path d="M12 12C9 9 7 6 7 4a5 5 0 0 1 10 0c0 3-2 5-5 8z"/>
                        <path d="M12 12c2-2 5-4 5-8"/>
                        {% else %}
                        <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z"/>
                        <path d="M12 8v4l3 3"/>
                        <path d="M12 6v1M12 17v1M6 12H5M19 12h-1M7.7 7.7l-.7-.7M17 17l-.7-.7M7.7 16.3l-.7.7M17 7l-.7.7"/>
                        {% endif %}
                    </svg>
                </div>
                <div class="but-content">
                    <h3 class="but-title">{{ but.title }}</h3>
                    <p class="but-lead">{{ but.lead }}</p>
                    <p class="but-text">{{ but.text }}</p>
                    <a href="{{ but.link_url }}" class="but-link">
                        {{ but.link_text }}
                        <svg class="arrow-icon" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                </div>
            </article>
            {% endfor %}
        </div>
    </div>
</section>

