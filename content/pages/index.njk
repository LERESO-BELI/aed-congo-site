<section id="contact" class="section-light">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">{{ contact.title }}</h2>
            <p class="section-subtitle">{{ contact.subtitle }}</p>
        </div>
        <div class="contact-grid">
            <div class="contact-card">
                <h3>Informations de contact</h3>
                <div class="contact-item">
                    <div class="contact-icon">📍</div>
                    <div class="contact-info-text">
                        <small>Adresse</small>
                        <span>16 rue Jean Pierre Ndébolo, Mbouono, Arr. 8 Madibou, Brazzaville, République du Congo</span>
                    </div>
                </div>
                <div class="contact-item">
                    <div class="contact-icon">📧</div>
                    <div class="contact-info-text">
                        <small>Email</small>
                        <span><a href="mailto:aedcongo2015@gmail.com">aedcongo2015@gmail.com</a></span>
                    </div>
                </div>
                <div class="contact-item">
                    <div class="contact-icon">📞</div>
                    <div class="contact-info-text">
                        <small>Téléphone</small>
                        <span>+242 06 952 2851</span>
                    </div>
                </div>
                <div class="contact-item">
                    <div class="contact-icon">🕐</div>
                    <div class="contact-info-text">
                        <small>Horaires</small>
                        <span>Lun - Ven : 8h00 - 17h00</span>
                    </div>
                </div>
            </div>
            <div class="contact-card">
                <h3>Envoyez-nous un message</h3>
                <form id="contactForm" action="https://api.web3forms.com/submit" method="POST">
                    <input type="hidden" name="access_key" value="{{ web3formsKey }}">
                    <input type="hidden" name="subject" value="Nouveau message — AED Congo">
                    <input type="hidden" name="redirect" value="https://aed-congo.org/merci">
                    <p class="hidden"><label>Don't fill this out if you're human: <input name="bot-field"></label></p>
                    <div class="form-group">
                        <label for="name">Nom complet</label>
                        <input type="text" id="name" name="name" required placeholder="Votre nom" minlength="2">
                        <div class="form-error" id="nameError">Veuillez entrer votre nom (minimum 2 caractères)</div>
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" required placeholder="votre@email.com">
                        <div class="form-error" id="emailError">Veuillez entrer une adresse email valide</div>
                    </div>
                    <div class="form-group">
                        <label for="message">Message</label>
                        <textarea id="message" name="message" required placeholder="Votre message..." minlength="10"></textarea>
                        <div class="form-error" id="messageError">Veuillez entrer votre message (minimum 10 caractères)</div>
                    </div>
                    <button type="submit" class="btn btn-primary">Envoyer le message</button>
                </form>
                <div id="formSuccess" role="alert">✅ Message envoyé ! Nous vous répondrons sous 48h.</div>
                <div id="formError" role="alert">❌ Une erreur s'est produite. Veuillez réessayer ou écrire directement à <a href="mailto:aedcongo2015@gmail.com">aedcongo2015@gmail.com</a>.</div>
            </div>
        </div>
    </div>
</section>

<!-- Visionneuse d'images (Lightbox) -->
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Visionneuse d'images">
    <button class="lightbox-close" onclick="closeLightbox()" aria-label="Fermer la visionneuse">&times;</button>
    <button class="lightbox-nav lightbox-prev" onclick="changeLightboxImage(-1)" aria-label="Image précédente">&#10094;</button>
    <div class="lightbox-content">
        <img id="lightboxImg" src="" alt="">
        <div class="lightbox-counter" id="lightboxCounter" aria-live="polite"></div>
        <div class="lightbox-caption" id="lightboxCaption"></div>
    </div>
    <button class="lightbox-nav lightbox-next" onclick="changeLightboxImage(1)" aria-label="Image suivante">&#10095;</button>
</div>

